{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "static",
  "installCommand": "pip install -r api/requirements.txt",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.7.0",
      "maxDuration": 30,
      "memory": 512
    }
  },
  "routes": [
    {
      "src": "/ask",
      "dest": "/api/index.py"
    },
    {
      "src": "/health",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/static/index.html"
    }
  ]
}
