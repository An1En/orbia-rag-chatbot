{
  "version": 2,
  "installCommand": "pip install -r api/requirements.txt",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.7.0",
      "maxDuration": 30,
      "memory": 512
    }
  },
  "routes": [
    { "src": "/ask", "dest": "/api/index.py" },
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/", "dest": "/api/index.py" }
  ]
}
